@model HantaWorld.AdminApi.Models.ArticleFormViewModel

<form method="post" class="card shadow-sm">
    <div class="card-body">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="OutbreakId" />
        <input type="hidden" asp-for="CountryId" />
        <input type="hidden" asp-for="ConfidenceScore" />
        <input type="hidden" asp-for="CoverImageUrl" />
        <input type="hidden" asp-for="VerificationNotes" />

        <div class="alert alert-info small">
            Bu ekran ana sayfadaki Salgın Raporları kartlarını ve /news raporlarını yönetir. Public sitede görünmesi için kayıt Doğrulanmış ve Yayında olmalıdır.
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Title" class="form-label">Rapor Başlığı</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="PublicId" class="form-label">Rapor ID</label>
                <input asp-for="PublicId" class="form-control" />
                <span asp-validation-for="PublicId" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Slug" class="form-label">URL slug</label>
                <input asp-for="Slug" class="form-control" />
                <span asp-validation-for="Slug" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Category" class="form-label">Kart Kategorisi</label>
                <select asp-for="Category" class="form-select">
                    <option value="outbreak-report">Salgın Raporu</option>
                    <option value="scientific-research">Araştırma</option>
                    <option value="public-health">Halk Sağlığı</option>
                    <option value="travel-advisory">Seyahat Uyarısı</option>
                    <option value="prevention">Önleme</option>
                    <option value="analysis">Analiz</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="PathogenId" class="form-label">Virüs / Kategori</label>
                <select asp-for="PathogenId" asp-items="Model.AvailablePathogens" class="form-select"></select>
                <div class="form-text">Bu seçim raporun hangi virüs sayfasında ve filtreli haber akışında görüneceğini belirler.</div>
            </div>
            <div class="col-md-3">
                <label asp-for="VerificationStatus" class="form-label">Doğrulama</label>
                <select asp-for="VerificationStatus" class="form-select">
                    <option value="verified">Doğrulanmış</option>
                    <option value="pending">Beklemede</option>
                    <option value="unverified">Doğrulanmamış</option>
                    <option value="rejected">Reddedildi</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="PublicationStatus" class="form-label">Yayın Durumu</label>
                <select asp-for="PublicationStatus" class="form-select">
                    <option value="draft">Taslak</option>
                    <option value="published">Yayında</option>
                    <option value="archived">Arşiv</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="ReadingTimeMin" class="form-label">Okuma</label>
                <input asp-for="ReadingTimeMin" class="form-control" type="number" min="1" max="120" />
            </div>

            <div class="col-12">
                <div class="form-check">
                    <input asp-for="SendPushOnPublish" class="form-check-input" />
                    <label asp-for="SendPushOnPublish" class="form-check-label">Yayınlanınca push bildirimi gönder</label>
                </div>
                <div class="form-text">
                    Bildirim yalnızca kayıt kaydedilirken Yayın Durumu = Yayında ve Doğrulama = Doğrulanmış ise gönderilir.
                    Taslak veya bekleyen kayıtlarda bildirim gönderilmez.
                    Gönderim durumunu <a href="/admin/mobile-push-debug" target="_blank" rel="noopener">Mobil Push Debug</a> ekranından kontrol edebilirsin.
                </div>
            </div>

            @if (Model.NotificationSendCount > 0)
            {
                <div class="col-12">
                    <div class="alert alert-warning small mb-0">
                        Bu rapor için push bildirimi daha önce @Model.NotificationSendCount kez gönderildi.
                        Son gönderim: @(Model.LastNotificationSentAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "bilinmiyor").
                    </div>
                </div>
            }

            <div class="col-12">
                <label asp-for="Excerpt" class="form-label">Özet</label>
                <textarea asp-for="Excerpt" rows="3" class="form-control"></textarea>
                <span asp-validation-for="Excerpt" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Content" class="form-label">İçerik</label>
                <textarea asp-for="Content" rows="12" class="form-control"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="PublicationDate" class="form-label">Yayın Tarihi</label>
                <input asp-for="PublicationDate" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="LastVerifiedDate" class="form-label">Son Doğrulama Tarihi</label>
                <input asp-for="LastVerifiedDate" class="form-control" />
            </div>

            <div class="col-12">
                <label asp-for="PrimarySourceUrl" class="form-label">Kaynak Linki</label>
                <input asp-for="PrimarySourceUrl" class="form-control" />
            </div>

            <div class="col-12">
                <label asp-for="SelectedSourceIds" class="form-label">Kaynak Rozetleri</label>
                <select asp-for="SelectedSourceIds" asp-items="Model.AvailableSources" class="form-select" multiple size="5"></select>
                <div class="form-text">İlk seçilen kaynak kartta görünür; diğerleri detay sayfasında kaynak olarak kullanılır.</div>
            </div>

            <div class="col-12">
                <label asp-for="TagsCsv" class="form-label">Etiketler</label>
                <input asp-for="TagsCsv" class="form-control" placeholder="Andes virus, MV Hondius, WHO" />
                <div class="form-text">Virgülle ayır. Kart altında hashtag olarak görünür.</div>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a class="btn btn-outline-secondary" href="/admin/articles">Geri</a>
    </div>
</form>

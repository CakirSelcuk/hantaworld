@model IEnumerable<HantaWorld.AdminApi.Domain.Article>
@{
    ViewData["Title"] = "Salgın Raporları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Salgın Raporları</h1>
        <div class="text-muted small">Ana sayfadaki rapor kartlarını ve /news sayfasındaki içerikleri buradan yönet.</div>
    </div>
    <a class="btn btn-primary" href="/admin/articles/create">Yeni Rapor</a>
</div>

@functions {
    private static string DisplayPublicationStatus(string? status)
    {
        return status switch
        {
            "draft" => "Taslak",
            "published" => "Yayında",
            "archived" => "Arşiv",
            _ => status ?? "-"
        };
    }

    private static string DisplayVerificationStatus(string? status)
    {
        return status switch
        {
            "verified" => "Doğrulanmış",
            "pending" => "Beklemede",
            "unverified" => "Doğrulanmamış",
            "rejected" => "Reddedildi",
            _ => status ?? "-"
        };
    }

    private static string PushUnavailableReason(HantaWorld.AdminApi.Domain.Article item)
    {
        if (item.PublicationStatus == "draft")
        {
            return "Taslak olduğu için gönderilemez";
        }

        if (item.VerificationStatus == "pending")
        {
            return "Doğrulama beklediği için gönderilemez";
        }

        return "Push için Yayında + Doğrulanmış olmalı";
    }
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead>
                <tr>
                    <th>Rapor</th>
                    <th>Kategori</th>
                    <th>Virüs / Kategori</th>
                    <th>Görünüm</th>
                    <th>Push</th>
                    <th>Tarih</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Title</div>
                        <div class="text-muted small">@item.Excerpt</div>
                    </td>
                    <td><span class="badge text-bg-secondary">@item.Category</span></td>
                    <td>
                        @if (item.Pathogen is not null)
                        {
                            <span class="badge text-bg-info">@item.Pathogen.DisplayName</span>
                        }
                        else
                        {
                            <span class="text-muted small">-</span>
                        }
                    </td>
                    <td>
                        <span class="badge text-bg-light">@DisplayVerificationStatus(item.VerificationStatus)</span>
                        <span class="badge text-bg-light">@DisplayPublicationStatus(item.PublicationStatus)</span>
                    </td>
                    <td>
                        <div class="small text-muted">
                            Gönderim: @item.NotificationSendCount
                        </div>
                        @if (item.LastNotificationSentAt.HasValue)
                        {
                            <div class="small text-muted">@item.LastNotificationSentAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        @if (item.NotificationSentAt.HasValue)
                        {
                            <div class="small text-muted">Bildirim daha önce gönderilmiş</div>
                        }
                    </td>
                    <td>
                        <div>@item.PublishedAt?.ToLocalTime().ToString("yyyy-MM-dd")</div>
                        <div class="text-muted small">@item.ReadingTimeMin dk okuma</div>
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="/admin/articles/@item.Id/edit">Düzenle</a>
                        @if (item.PublicationStatus == "published" && item.VerificationStatus == "verified")
                        {
                            <form method="post" action="/admin/articles/@item.Id/send-push" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="confirmResend" value="@(item.NotificationSendCount > 0 ? "true" : "false")" />
                                <button
                                    type="submit"
                                    class="btn btn-sm btn-outline-success"
                                    onclick="@(item.NotificationSendCount > 0 ? "return confirm('Bu rapor için daha önce bildirim gönderildi. Tekrar gönderilsin mi?');" : "return confirm('Bu rapor için push bildirimi gönderilsin mi?');")">
                                    Push Gönder
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="small text-muted mt-1">@PushUnavailableReason(item)</div>
                        }
                        <form method="post" action="/admin/articles/@item.Id/delete" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Rapor silinsin mi?');">Sil</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@model HantaWorld.AdminApi.Models.SourceFormViewModel

<form method="post" class="card shadow-sm">
    <div class="card-body">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Organization" class="form-label"></label><input asp-for="Organization" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="Slug" class="form-label"></label><input asp-for="Slug" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="SourceType" class="form-label"></label><input asp-for="SourceType" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="ReliabilityScore" class="form-label"></label><input asp-for="ReliabilityScore" class="form-control" /></div>
            <div class="col-12"><label asp-for="Url" class="form-label"></label><input asp-for="Url" class="form-control" /></div>
            <div class="col-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" rows="4" class="form-control"></textarea></div>
            <div class="col-md-6 form-check"><input asp-for="IsOfficial" class="form-check-input" /><label asp-for="IsOfficial" class="form-check-label"></label></div>
            <div class="col-md-6 form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a class="btn btn-outline-secondary" href="/admin/sources">Geri</a>
    </div>
</form>

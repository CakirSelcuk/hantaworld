@using HantaWorld.AdminApi.Domain
@{
    ViewData["Title"] = "Admin Panel";
    var auditLogs = ViewData["AuditLogs"] as IEnumerable<AuditLog> ?? Enumerable.Empty<AuditLog>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Admin Panel</h1>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Toplam Salgın</div><div class="h2 mb-0">@ViewData["OutbreakCount"]</div></div></div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Toplam Haber</div><div class="h2 mb-0">@ViewData["ArticleCount"]</div></div></div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Bekleyen Doğrulama</div><div class="h2 mb-0">@ViewData["PendingVerificationCount"]</div></div></div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h2 class="h5 mb-3">Son Audit Kayıtları</h2>
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Zaman</th>
                        <th>İşlem</th>
                        <th>Varlık</th>
                        <th>Public ID</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in auditLogs)
                    {
                        <tr>
                            <td>@log.CreatedAt.ToLocalTime()</td>
                            <td>@log.ActionType</td>
                            <td>@log.EntityName</td>
                            <td>@log.EntityPublicId</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

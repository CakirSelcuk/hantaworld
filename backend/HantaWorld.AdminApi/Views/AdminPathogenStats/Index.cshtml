@model HantaWorld.AdminApi.Models.PathogenStatsFormViewModel
@{
    ViewData["Title"] = "Salgın İstatistikleri";
}

@functions {
    private static string DisplayNumber(int? value) => value.HasValue ? value.Value.ToString("N0") : "-";
    private static string DisplayDate(DateOnly? value) => value.HasValue ? value.Value.ToString("yyyy-MM-dd") : "-";
    private static string DisplayDateTime(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Salgın İstatistikleri</h1>
        <div class="text-muted small">Virüs veya kategori bazlı güncel vaka, ölüm ve salgın sayılarını buradan gir.</div>
    </div>
    <div class="d-flex gap-2">
        @if (!string.IsNullOrWhiteSpace(Model.PublicPageUrl))
        {
            <a class="btn btn-outline-primary" href="@Model.PublicPageUrl" target="_blank" rel="noopener">Sitede Gör</a>
        }
        <a class="btn btn-outline-secondary" href="/admin/articles">Salgın Raporlarına Dön</a>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

<div class="alert alert-info small">
    Bu ekran sayısal verileri günceller. Buraya girdiğin veriler sitedeki istatistik kartlarını ve grafikleri besler.
    Haber veya açıklama girmek için Salgın Raporları ekranını kullan.
</div>

<form method="get" action="/admin/pathogen-stats" class="card shadow-sm mb-4">
    <div class="card-body">
        <label class="form-label fw-semibold" for="pathogenSlug">Virüs / Kategori</label>
        <div class="d-flex gap-2">
            <select id="pathogenSlug" name="pathogenSlug" class="form-select" asp-items="Model.AvailablePathogens"></select>
            <button type="submit" class="btn btn-outline-primary">Yükle</button>
        </div>
        <div class="form-text">İstatistik girmek veya kayıt geçmişini görmek için virüs/kategori seç.</div>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
                <div class="fw-semibold">Mevcut Değerler</div>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="text-muted small">Seçili virüs/kategori</div>
                        <h2 class="h5 mb-1">@(Model.PathogenDisplayName ?? "Aktif virüs/kategori bulunamadı")</h2>
                        @if (!string.IsNullOrWhiteSpace(Model.PathogenSlug))
                        {
                            <div class="small text-muted">/@Model.PathogenSlug</div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PathogenColor))
                    {
                        <span class="badge rounded-pill" style="background:@Model.PathogenColor; color:#fff;">Profil rengi</span>
                    }
                </div>

                @if (!Model.CurrentReportedCases.HasValue &&
                     !Model.CurrentTotalDeaths.HasValue &&
                     !Model.CurrentAffectedCountries.HasValue &&
                     !Model.CurrentActiveOutbreaks.HasValue)
                {
                    <div class="alert alert-secondary small">Bu virüs için doğrulanmış istatistik bulunmuyor.</div>
                }

                <div class="row g-3">
                    <div class="col-sm-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Vaka Sayısı</div>
                            <div class="fs-4 fw-semibold">@DisplayNumber(Model.CurrentReportedCases)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Ölüm Sayısı</div>
                            <div class="fs-4 fw-semibold">@DisplayNumber(Model.CurrentTotalDeaths)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Etkilenen Ülke</div>
                            <div class="fs-4 fw-semibold">@DisplayNumber(Model.CurrentAffectedCountries)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Aktif Salgın</div>
                            <div class="fs-4 fw-semibold">@DisplayNumber(Model.CurrentActiveOutbreaks)</div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="row g-3 small">
                    <div class="col-md-4">
                        <div class="text-muted">Kaynak Kurum</div>
                        <div>@(string.IsNullOrWhiteSpace(Model.CurrentSourceInstitution) ? "-" : Model.CurrentSourceInstitution)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Resmi Yayın Tarihi</div>
                        <div>@DisplayDate(Model.CurrentOfficialPublishedAt)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Son Doğrulama Tarihi</div>
                        <div>@DisplayDate(Model.CurrentLastVerifiedAt)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Oluşturma</div>
                        <div>@DisplayDateTime(Model.CurrentCreatedAt)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Son Güncelleme</div>
                        <div>@DisplayDateTime(Model.CurrentUpdatedAt)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Kaynak Linki</div>
                        @if (!string.IsNullOrWhiteSpace(Model.CurrentSourceUrl))
                        {
                            <a href="@Model.CurrentSourceUrl" target="_blank" rel="noopener">Kaynağı Aç</a>
                        }
                        else
                        {
                            <div>-</div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.CurrentNotes))
                {
                    <div class="mt-3 small">
                        <div class="text-muted">Notlar</div>
                        <div class="border rounded p-2 bg-light">@Model.CurrentNotes</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
                <div class="fw-semibold">Kısa Akış</div>
            </div>
            <div class="card-body">
                <ol class="small mb-3">
                    <li>Virüs veya kategori seç.</li>
                    <li>Mevcut değerleri kontrol et.</li>
                    <li>Sadece doğrulanmış sayıları gir.</li>
                    <li>Kaydet; aynı tarihli geçmiş kaydı güncellenir.</li>
                    <li>Sitede Gör ile public sayfayı kontrol et.</li>
                </ol>
                <div class="alert alert-warning small mb-0">
                    Doğrulanmış sayı yoksa alanlar boş kalabilir. Negatif değer girilemez.
                </div>
            </div>
        </div>
    </div>
</div>

<form method="post" class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <div class="fw-semibold">Verileri Güncelle</div>
        <div class="text-muted small">Son Doğrulama Tarihi grafik kayıt tarihi olarak kullanılır. Boş bırakılırsa bugünün UTC tarihi kullanılır.</div>
    </div>
    <div class="card-body">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="PathogenId" />
        <input type="hidden" asp-for="PathogenSlug" />

        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="ReportedCases" class="form-label">Vaka Sayısı</label>
                <input asp-for="ReportedCases" class="form-control" type="number" min="0" />
                <span asp-validation-for="ReportedCases" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="TotalDeaths" class="form-label">Ölüm Sayısı</label>
                <input asp-for="TotalDeaths" class="form-control" type="number" min="0" />
                <span asp-validation-for="TotalDeaths" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="AffectedCountries" class="form-label">Etkilenen Ülke</label>
                <input asp-for="AffectedCountries" class="form-control" type="number" min="0" />
                <span asp-validation-for="AffectedCountries" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="ActiveOutbreaks" class="form-label">Aktif Salgın</label>
                <input asp-for="ActiveOutbreaks" class="form-control" type="number" min="0" />
                <span asp-validation-for="ActiveOutbreaks" class="text-danger small"></span>
            </div>
        </div>
    </div>

    <div class="card-header bg-white border-top">
        <div class="fw-semibold">Kaynak ve Doğrulama</div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="SourceInstitution" class="form-label">Kaynak Kurum</label>
                <input asp-for="SourceInstitution" class="form-control" placeholder="WHO, CDC, ECDC veya sağlık bakanlığı" />
                <div class="form-text">Zorunlu değil, ama önerilir.</div>
                <span asp-validation-for="SourceInstitution" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="SourceUrl" class="form-label">Kaynak Linki</label>
                <input asp-for="SourceUrl" class="form-control" placeholder="https://..." />
                <div class="form-text">Zorunlu değil. Girilirse geçerli bir link olmalı.</div>
                <span asp-validation-for="SourceUrl" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="OfficialPublishedAt" class="form-label">Resmi Yayın Tarihi</label>
                <input asp-for="OfficialPublishedAt" class="form-control" type="date" />
                <span asp-validation-for="OfficialPublishedAt" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastVerifiedAt" class="form-label">Son Doğrulama Tarihi</label>
                <input asp-for="LastVerifiedAt" class="form-control" type="date" />
                <div class="form-text">Önerilir. Grafik geçmişinde kayıt tarihi olarak kullanılır.</div>
                <span asp-validation-for="LastVerifiedAt" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Notes" class="form-label">Notlar</label>
                <textarea asp-for="Notes" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <button type="submit" class="btn btn-primary" @(Model.PathogenId == Guid.Empty ? "disabled" : "")>Kaydet</button>
        @if (!string.IsNullOrWhiteSpace(Model.PublicPageUrl))
        {
            <a class="btn btn-outline-primary" href="@Model.PublicPageUrl" target="_blank" rel="noopener">Sitede Gör</a>
        }
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div>
            <div class="fw-semibold">Son Kayıt Geçmişi</div>
            <div class="text-muted small">Seçili virüs/kategori için son 20 kayıt. Aynı kayıt tarihi tekrar kaydedilirse yeni satır açılmaz, mevcut satır güncellenir.</div>
        </div>
        <span class="badge text-bg-secondary">@Model.LatestHistory.Count kayıt</span>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>Kayıt Tarihi</th>
                    <th>Vaka Sayısı</th>
                    <th>Ölüm Sayısı</th>
                    <th>Etkilenen Ülke</th>
                    <th>Aktif Salgın</th>
                    <th>Kaynak Kurum</th>
                    <th>Kaynak Linki</th>
                    <th>Oluşturma / Güncelleme</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.LatestHistory.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-muted">Henüz kayıt yok.</td>
                </tr>
            }
            else
            {
                foreach (var row in Model.LatestHistory)
                {
                    <tr>
                        <td>@row.SnapshotDate.ToString("yyyy-MM-dd")</td>
                        <td>@DisplayNumber(row.ReportedCases)</td>
                        <td>@DisplayNumber(row.TotalDeaths)</td>
                        <td>@DisplayNumber(row.AffectedCountries)</td>
                        <td>@DisplayNumber(row.ActiveOutbreaks)</td>
                        <td>@(string.IsNullOrWhiteSpace(row.SourceInstitution) ? "-" : row.SourceInstitution)</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.SourceUrl))
                            {
                                <a href="@row.SourceUrl" target="_blank" rel="noopener">Aç</a>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td class="small">
                            <div>@row.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            <div class="text-muted">@row.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@model HantaWorld.AdminApi.Models.PathogenStatsFormViewModel
@{
    ViewData["Title"] = "Pathogen Stats";
}

@functions {
    private static string DisplayNumber(int? value) => value.HasValue ? value.Value.ToString("N0") : "-";
    private static string DisplayDate(DateOnly? value) => value.HasValue ? value.Value.ToString("yyyy-MM-dd") : "-";
    private static string DisplayDateTime(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Pathogen Stats</h1>
        <div class="text-muted small">Current numeric stats and chart history for public pathogen/category pages.</div>
    </div>
    <div class="d-flex gap-2">
        @if (!string.IsNullOrWhiteSpace(Model.PublicPageUrl))
        {
            <a class="btn btn-outline-primary" href="@Model.PublicPageUrl" target="_blank" rel="noopener">View public page</a>
        }
        <a class="btn btn-outline-secondary" href="/admin/articles">Back to Intelligence Feed</a>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

<div class="alert alert-info small">
    Stats are optional for category-like entries such as official updates and weekly risk briefs. Saving updates the current row and upserts one history row for the selected snapshot date.
</div>

<form method="get" action="/admin/pathogen-stats" class="card shadow-sm mb-4">
    <div class="card-body">
        <label class="form-label fw-semibold" for="pathogenSlug">Pathogen / Category</label>
        <div class="d-flex gap-2">
            <select id="pathogenSlug" name="pathogenSlug" class="form-select" asp-items="Model.AvailablePathogens"></select>
            <button type="submit" class="btn btn-outline-primary">Load</button>
        </div>
        <div class="form-text">Select a pathogen/category before editing stats or reviewing chart history.</div>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="text-muted small">Selected pathogen/category</div>
                        <h2 class="h5 mb-1">@(Model.PathogenDisplayName ?? "No active pathogen/category found")</h2>
                        @if (!string.IsNullOrWhiteSpace(Model.PathogenSlug))
                        {
                            <div class="small text-muted">/@Model.PathogenSlug</div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PathogenColor))
                    {
                        <span class="badge rounded-pill" style="background:@Model.PathogenColor; color:#fff;">Profile color</span>
                    }
                </div>

                <div class="row g-3">
                    <div class="col-sm-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Reported Cases</div>
                            <div class="fs-4 fw-semibold">@DisplayNumber(Model.CurrentReportedCases)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Total Deaths</div>
                            <div class="fs-4 fw-semibold">@DisplayNumber(Model.CurrentTotalDeaths)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Affected Countries</div>
                            <div class="fs-4 fw-semibold">@DisplayNumber(Model.CurrentAffectedCountries)</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Active Outbreaks</div>
                            <div class="fs-4 fw-semibold">@DisplayNumber(Model.CurrentActiveOutbreaks)</div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="row g-3 small">
                    <div class="col-md-4">
                        <div class="text-muted">Source Institution</div>
                        <div>@(string.IsNullOrWhiteSpace(Model.CurrentSourceInstitution) ? "-" : Model.CurrentSourceInstitution)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Official Published Date</div>
                        <div>@DisplayDate(Model.CurrentOfficialPublishedAt)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Last Verified Date</div>
                        <div>@DisplayDate(Model.CurrentLastVerifiedAt)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Created</div>
                        <div>@DisplayDateTime(Model.CurrentCreatedAt)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Last Updated</div>
                        <div>@DisplayDateTime(Model.CurrentUpdatedAt)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted">Source URL</div>
                        @if (!string.IsNullOrWhiteSpace(Model.CurrentSourceUrl))
                        {
                            <a href="@Model.CurrentSourceUrl" target="_blank" rel="noopener">Open source</a>
                        }
                        else
                        {
                            <div>-</div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.CurrentNotes))
                {
                    <div class="mt-3 small">
                        <div class="text-muted">Notes</div>
                        <div class="border rounded p-2 bg-light">@Model.CurrentNotes</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6">Workflow</h2>
                <ol class="small mb-3">
                    <li>Select pathogen/category.</li>
                    <li>Review current saved stats.</li>
                    <li>Edit only verified values you have.</li>
                    <li>Save to update current stats and same-day history.</li>
                    <li>Open the public page to verify display.</li>
                </ol>
                <div class="alert alert-warning small mb-0">
                    Numeric values may be left empty when verified values are not available. Negative values are blocked.
                </div>
            </div>
        </div>
    </div>
</div>

<form method="post" class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <div class="fw-semibold">Edit stats</div>
        <div class="text-muted small">Last Verified Date is recommended and is used as the chart snapshot date. If empty, UTC today is used.</div>
    </div>
    <div class="card-body">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="PathogenId" />
        <input type="hidden" asp-for="PathogenSlug" />

        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="ReportedCases" class="form-label">Reported Cases</label>
                <input asp-for="ReportedCases" class="form-control" type="number" min="0" />
                <span asp-validation-for="ReportedCases" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="TotalDeaths" class="form-label">Total Deaths</label>
                <input asp-for="TotalDeaths" class="form-control" type="number" min="0" />
                <span asp-validation-for="TotalDeaths" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="AffectedCountries" class="form-label">Affected Countries</label>
                <input asp-for="AffectedCountries" class="form-control" type="number" min="0" />
                <span asp-validation-for="AffectedCountries" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="ActiveOutbreaks" class="form-label">Active Outbreaks</label>
                <input asp-for="ActiveOutbreaks" class="form-control" type="number" min="0" />
                <span asp-validation-for="ActiveOutbreaks" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="SourceInstitution" class="form-label">Source Institution</label>
                <input asp-for="SourceInstitution" class="form-control" placeholder="WHO, CDC, ECDC, ministry, etc." />
                <div class="form-text">Optional, but recommended for source-attributed public display.</div>
                <span asp-validation-for="SourceInstitution" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="SourceUrl" class="form-label">Source URL</label>
                <input asp-for="SourceUrl" class="form-control" placeholder="https://..." />
                <div class="form-text">Optional. If provided, it must be a valid URL.</div>
                <span asp-validation-for="SourceUrl" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="OfficialPublishedAt" class="form-label">Official Published Date</label>
                <input asp-for="OfficialPublishedAt" class="form-control" type="date" />
                <span asp-validation-for="OfficialPublishedAt" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastVerifiedAt" class="form-label">Last Verified Date</label>
                <input asp-for="LastVerifiedAt" class="form-control" type="date" />
                <div class="form-text">Recommended. Used as the history snapshot date. If empty, UTC today is used.</div>
                <span asp-validation-for="LastVerifiedAt" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <button type="submit" class="btn btn-primary" @(Model.PathogenId == Guid.Empty ? "disabled" : "")>Save stats</button>
        @if (!string.IsNullOrWhiteSpace(Model.PublicPageUrl))
        {
            <a class="btn btn-outline-primary" href="@Model.PublicPageUrl" target="_blank" rel="noopener">View public page</a>
        }
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div>
            <div class="fw-semibold">Latest history entries</div>
            <div class="text-muted small">Latest 20 rows for the selected pathogen/category. Same snapshot date is updated, not duplicated.</div>
        </div>
        <span class="badge text-bg-secondary">@Model.LatestHistory.Count row(s)</span>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>Snapshot Date</th>
                    <th>Reported Cases</th>
                    <th>Total Deaths</th>
                    <th>Affected Countries</th>
                    <th>Active Outbreaks</th>
                    <th>Source Institution</th>
                    <th>Source URL</th>
                    <th>Created / Updated</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.LatestHistory.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-muted">No history records yet.</td>
                </tr>
            }
            else
            {
                foreach (var row in Model.LatestHistory)
                {
                    <tr>
                        <td>@row.SnapshotDate.ToString("yyyy-MM-dd")</td>
                        <td>@DisplayNumber(row.ReportedCases)</td>
                        <td>@DisplayNumber(row.TotalDeaths)</td>
                        <td>@DisplayNumber(row.AffectedCountries)</td>
                        <td>@DisplayNumber(row.ActiveOutbreaks)</td>
                        <td>@(string.IsNullOrWhiteSpace(row.SourceInstitution) ? "-" : row.SourceInstitution)</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.SourceUrl))
                            {
                                <a href="@row.SourceUrl" target="_blank" rel="noopener">Open</a>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td class="small">
                            <div>@row.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            <div class="text-muted">@row.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@model HantaWorld.AdminApi.Models.PathogenResearchViewModel
@{
    ViewData["Title"] = "Kaynaklı Virüs Taraması";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Kaynaklı Virüs Taraması</h1>
        <div class="text-muted small">
            Seçtiğin virüs için resmi kaynakları kontrol eder ve Salgın Raporları ekranına uygun İngilizce taslak hazırlar.
        </div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/admin/pathogen-stats">Salgın İstatistikleri</a>
        <a class="btn btn-outline-secondary" href="/admin/articles">Salgın Raporları</a>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-warning">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.CreatedArticleEditUrl))
{
    <div class="alert alert-success">
        Taslak rapor oluşturuldu.
        <a href="@Model.CreatedArticleEditUrl" class="alert-link">Düzenlemek için aç</a>.
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.SimilarArticleEditUrl))
{
    <div class="alert alert-warning">
        Benzer bir taslak rapor zaten var.
        <a href="@Model.SimilarArticleEditUrl" class="alert-link">Mevcut taslağı aç</a>.
    </div>
}

<div class="alert alert-warning small">
    Sayılar otomatik kaydedilmez. Rapor sadece sen onaylarsan taslak olarak oluşturulur.
</div>

<form method="post" class="card shadow-sm mb-4">
    <div class="card-body">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label asp-for="SelectedPathogenSlug" class="form-label">Virüs / Kategori</label>
                <select asp-for="SelectedPathogenSlug" asp-items="Model.AvailablePathogens" class="form-select"></select>
                <span asp-validation-for="SelectedPathogenSlug" class="text-danger small"></span>
            </div>
            <div class="col-lg-3">
                <div class="form-check">
                    <input asp-for="SearchRecentOnly" class="form-check-input" />
                    <label asp-for="SearchRecentOnly" class="form-check-label">Son güncel gelişmeleri tara</label>
                </div>
                <div class="form-text">Sadece önceden tanımlı resmi kaynaklar taranır.</div>
            </div>
            <div class="col-lg-2">
                <label asp-for="DateFrom" class="form-label">Başlangıç</label>
                <input asp-for="DateFrom" class="form-control" type="date" />
            </div>
            <div class="col-lg-2">
                <label asp-for="DateTo" class="form-label">Bitiş</label>
                <input asp-for="DateTo" class="form-control" type="date" />
            </div>
            <div class="col-lg-1 d-grid">
                <button type="submit" class="btn btn-primary">Tarama Yap</button>
            </div>
        </div>
    </div>
</form>

@if (Model.Output is null)
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">Bir virüs seçip tarama başlat.</div>
    </div>
}
else
{
    var reachedSources = Model.Output.FetchedSources.Where(x => x.IsSuccess).ToList();
    var failedSources = Model.Output.FetchedSources.Where(x => !x.IsSuccess).ToList();
    var statisticsLines = Model.Output.StatisticsText.Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries);

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <div class="fw-semibold">Salgın Raporu Taslağı</div>
            <div class="text-muted small">Aşağıdaki alanlar Salgın Raporları formundaki sıraya göre hazırlanır. İçerik İngilizcedir.</div>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-md-3">Rapor Başlığı</dt>
                <dd class="col-md-9">@Model.Output.ReportTitle</dd>

                <dt class="col-md-3">Rapor ID</dt>
                <dd class="col-md-9">@Model.Output.PublicIdNote</dd>

                <dt class="col-md-3">URL Slug</dt>
                <dd class="col-md-9"><code>@Model.Output.SuggestedSlug</code></dd>

                <dt class="col-md-3">Kart Kategorisi</dt>
                <dd class="col-md-9">@Model.Output.ReportTypeLabel <span class="text-muted small">(@Model.Output.ReportType)</span></dd>

                <dt class="col-md-3">Virüs / Kategori</dt>
                <dd class="col-md-9">@Model.SelectedPathogenDisplayName</dd>

                <dt class="col-md-3">Doğrulama</dt>
                <dd class="col-md-9">@Model.Output.VerificationStatusLabel <span class="text-muted small">(@Model.Output.VerificationStatus)</span></dd>

                <dt class="col-md-3">Yayın Durumu</dt>
                <dd class="col-md-9">@Model.Output.PublicationStatusLabel <span class="text-muted small">(@Model.Output.PublicationStatus)</span></dd>

                <dt class="col-md-3">Okuma</dt>
                <dd class="col-md-9">@Model.Output.ReadingTimeMin min read</dd>

                <dt class="col-md-3">Özet</dt>
                <dd class="col-md-9">@Model.Output.ReportSummary</dd>

                <dt class="col-md-3">İçerik</dt>
                <dd class="col-md-9">
                    <div class="border rounded p-3 bg-light small" style="white-space: pre-wrap;">@Model.Output.ReportContent</div>
                </dd>

                <dt class="col-md-3">Kaynak Kurum</dt>
                <dd class="col-md-9">@Model.Output.SourceInstitution</dd>

                <dt class="col-md-3">Kaynak Linki</dt>
                <dd class="col-md-9">
                    @if (string.IsNullOrWhiteSpace(Model.Output.SourceUrl))
                    {
                        <span class="text-muted">Kaynaklardan kontrol et.</span>
                    }
                    else
                    {
                        <a href="@Model.Output.SourceUrl" target="_blank" rel="noopener">@Model.Output.SourceUrl</a>
                    }
                </dd>

                <dt class="col-md-3">Yayın Tarihi</dt>
                <dd class="col-md-9">@Model.Output.PublicationDate.ToString("yyyy-MM-dd")</dd>
            </dl>
        </div>
        <div class="card-footer d-flex align-items-center gap-2">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#draftConfirmModal">
                Raporu Taslak Olarak Kaydet
            </button>
            <span class="text-muted small">Taslak + Beklemede olarak kaydedilir. Push gönderilmez, istatistik güncellenmez.</span>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <div class="fw-semibold">Salgın İstatistikleri için sayı önerileri</div>
            <div class="text-muted small">Bu bölüm yalnızca kontrol içindir; DB'ye kaydedilmez ve grafikleri güncellemez.</div>
        </div>
        <div class="card-body">
            @if (statisticsLines.Length == 0)
            {
                <div class="text-muted">Doğrulanmış sayı bulunamadı.</div>
            }
            else
            {
                <ul class="mb-0">
                    @foreach (var line in statisticsLines)
                    {
                        <li>@line</li>
                    }
                </ul>
            }
        </div>
    </div>

    <details class="card shadow-sm mb-4">
        <summary class="card-header bg-white fw-semibold" style="cursor: pointer;">Kaynak Kontrolü</summary>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-lg-6">
                    <h2 class="h6">Ulaşılan kaynaklar</h2>
                    @if (reachedSources.Count == 0)
                    {
                        <div class="text-muted small">Resmi kaynaklara ulaşılamadı.</div>
                    }
                    else
                    {
                        <ul class="small">
                            @foreach (var source in reachedSources)
                            {
                                <li>
                                    <strong>@source.Institution:</strong>
                                    @(source.Title ?? "Başlık çıkarılamadı")
                                    <a href="@source.Url" target="_blank" rel="noopener">Aç</a>
                                </li>
                            }
                        </ul>
                    }
                </div>
                <div class="col-lg-6">
                    <h2 class="h6">Ulaşılamayan kaynaklar</h2>
                    @if (failedSources.Count == 0)
                    {
                        <div class="text-muted small">Ulaşılamayan kaynak yok.</div>
                    }
                    else
                    {
                        <ul class="small">
                            @foreach (var source in failedSources)
                            {
                                <li><strong>@source.Institution:</strong> @(source.ErrorMessage ?? "Kaynağa ulaşılamadı.")</li>
                            }
                        </ul>
                    }
                </div>
                <div class="col-12">
                    <h2 class="h6">Kullanılan ana kaynak</h2>
                    @if (string.IsNullOrWhiteSpace(Model.Output.SourceUrl))
                    {
                        <div class="text-muted small">Ana kaynak otomatik belirlenemedi.</div>
                    }
                    else
                    {
                        <a href="@Model.Output.SourceUrl" target="_blank" rel="noopener">@Model.Output.SourceUrl</a>
                    }
                </div>
                <div class="col-12">
                    <h2 class="h6">Admin kontrol notu</h2>
                    <div class="text-muted small">@Model.Output.AdminNote</div>
                </div>
            </div>
        </div>
    </details>

    <div class="modal fade" id="draftConfirmModal" tabindex="-1" aria-labelledby="draftConfirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="draftConfirmModalLabel">Taslak Raporu Kontrol Et</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-md-3">Rapor Başlığı</dt>
                        <dd class="col-md-9">@Model.Output.ReportTitle</dd>
                        <dt class="col-md-3">Rapor ID</dt>
                        <dd class="col-md-9">@Model.Output.PublicIdNote</dd>
                        <dt class="col-md-3">URL Slug</dt>
                        <dd class="col-md-9"><code>@Model.Output.SuggestedSlug</code></dd>
                        <dt class="col-md-3">Kart Kategorisi</dt>
                        <dd class="col-md-9">@Model.Output.ReportTypeLabel</dd>
                        <dt class="col-md-3">Virüs / Kategori</dt>
                        <dd class="col-md-9">@Model.SelectedPathogenDisplayName</dd>
                        <dt class="col-md-3">Doğrulama</dt>
                        <dd class="col-md-9">@Model.Output.VerificationStatusLabel</dd>
                        <dt class="col-md-3">Yayın Durumu</dt>
                        <dd class="col-md-9">@Model.Output.PublicationStatusLabel</dd>
                        <dt class="col-md-3">Okuma</dt>
                        <dd class="col-md-9">@Model.Output.ReadingTimeMin min read</dd>
                        <dt class="col-md-3">Yayın Tarihi</dt>
                        <dd class="col-md-9">@Model.Output.PublicationDate.ToString("yyyy-MM-dd")</dd>
                        <dt class="col-md-3">Özet</dt>
                        <dd class="col-md-9">@Model.Output.ReportSummary</dd>
                        <dt class="col-md-3">İçerik</dt>
                        <dd class="col-md-9">
                            <div class="border rounded p-3 bg-light small" style="white-space: pre-wrap;">@Model.Output.ReportContent</div>
                        </dd>
                        <dt class="col-md-3">Kaynak Linki</dt>
                        <dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.Output.SourceUrl) ? "Kaynaklardan kontrol et." : Model.Output.SourceUrl)</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <form method="post" action="/admin/pathogen-research/create-draft" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="SelectedPathogenSlug" />
                        <input type="hidden" asp-for="SearchRecentOnly" />
                        <input type="hidden" asp-for="DateFrom" />
                        <input type="hidden" asp-for="DateTo" />
                        <button type="submit" class="btn btn-primary">Onayla ve Taslak Kaydet</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

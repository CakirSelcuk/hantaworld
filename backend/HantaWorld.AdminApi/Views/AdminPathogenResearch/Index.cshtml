@model HantaWorld.AdminApi.Models.PathogenResearchViewModel
@{
    ViewData["Title"] = "Kaynaklı Virüs Taraması";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Kaynaklı Virüs Taraması</h1>
        <div class="text-muted small">
            Resmi kaynaklara göre sayı önerisi ve rapor taslağı hazırlar. Sayılar otomatik kaydedilmez.
            Raporu sen onaylarsan Salgın Raporları içine taslak olarak eklenir.
        </div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/admin/pathogen-stats">Salgın İstatistikleri</a>
        <a class="btn btn-outline-secondary" href="/admin/articles">Salgın Raporları</a>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-warning">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.CreatedArticleEditUrl))
{
    <div class="alert alert-success">
        Rapor taslak olarak oluşturuldu.
        <a href="@Model.CreatedArticleEditUrl" class="alert-link">Düzenlemek için aç</a>.
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.SimilarArticleEditUrl))
{
    <div class="alert alert-warning">
        Benzer bir taslak rapor zaten var.
        <a href="@Model.SimilarArticleEditUrl" class="alert-link">Mevcut taslağı aç</a>.
    </div>
}

<div class="alert alert-warning small">
    Sağlık verileri kritik olduğu için sonuçları yayınlamadan önce kaynak linklerinden kontrol et.
    Bu ekran sayısal veriyi otomatik olarak Salgın İstatistikleri tablosuna kaydetmez ve raporu otomatik yayınlamaz.
</div>

<form method="post" class="card shadow-sm mb-4">
    <div class="card-body">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label asp-for="SelectedPathogenSlug" class="form-label">Virüs / Kategori</label>
                <select asp-for="SelectedPathogenSlug" asp-items="Model.AvailablePathogens" class="form-select"></select>
                <span asp-validation-for="SelectedPathogenSlug" class="text-danger small"></span>
            </div>
            <div class="col-lg-3">
                <div class="form-check">
                    <input asp-for="SearchRecentOnly" class="form-check-input" />
                    <label asp-for="SearchRecentOnly" class="form-check-label">Son güncel gelişmeleri tara</label>
                </div>
                <div class="form-text">Bu sürüm güvenilir kaynak kontrol şablonu üretir; otomatik yayın yapmaz.</div>
            </div>
            <div class="col-lg-2">
                <label asp-for="DateFrom" class="form-label">Başlangıç</label>
                <input asp-for="DateFrom" class="form-control" type="date" />
            </div>
            <div class="col-lg-2">
                <label asp-for="DateTo" class="form-label">Bitiş</label>
                <input asp-for="DateTo" class="form-control" type="date" />
            </div>
            <div class="col-lg-1 d-grid">
                <button type="submit" class="btn btn-primary">Tarama Yap</button>
            </div>
        </div>
    </div>
</form>

@if (Model.Output is null)
{
    <div class="card shadow-sm">
        <div class="card-body text-muted">Bir virüs seçip tarama başlat.</div>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold">Salgın İstatistikleri için önerilen sayılar</div>
                        <div class="text-muted small">
                            Bu sayılar otomatik kaydedilmez. Kontrol ettikten sonra Salgın İstatistikleri ekranına elle gir.
                            Doğrulanmış veri yoksa 0 üretilmez.
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-primary" data-copy-target="statisticsOutput">Sayıları Kopyala</button>
                </div>
                <div class="card-body">
                    <textarea id="statisticsOutput" class="form-control font-monospace small" rows="11" readonly>@Model.Output.StatisticsText</textarea>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold">Salgın Raporları için taslak</div>
                        <div class="text-muted small">Taslak rapordur; kaynak doğrulaması sonrası elle düzenlenmelidir.</div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-primary" data-copy-target="reportOutput">Raporu Kopyala</button>
                </div>
                <div class="card-body">
                    <textarea id="reportOutput" class="form-control font-monospace small" rows="10" readonly>@Model.Output.ReportText</textarea>

                    <form method="post" action="/admin/pathogen-research/create-draft" class="mt-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="SelectedPathogenSlug" />
                        <input type="hidden" asp-for="SearchRecentOnly" />
                        <input type="hidden" asp-for="DateFrom" />
                        <input type="hidden" asp-for="DateTo" />
                        <button type="submit" class="btn btn-primary">Raporu Taslak Olarak Kaydet</button>
                        <span class="text-muted small ms-2">
                            Sadece draft + pending olarak kaydedilir; yayınlamak için raporu düzenleyip onaylaman gerekir.
                        </span>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold">Kaynaklar</div>
                        <div class="text-muted small">Sadece resmi veya güvenilir halk sağlığı kaynakları listelenir.</div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-primary" data-copy-target="sourcesOutput">Kaynakları Kopyala</button>
                </div>
                <div class="card-body">
                    <textarea id="sourcesOutput" class="form-control font-monospace small mb-3" rows="8" readonly>@Model.Output.SourcesText</textarea>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>Kurum</th>
                                <th>Link</th>
                                <th>Not</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var source in Model.Output.Sources)
                            {
                                <tr>
                                    <td>@source.Institution</td>
                                    <td><a href="@source.Url" target="_blank" rel="noopener">@source.Url</a></td>
                                    <td class="text-muted small">@source.Note</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="alert alert-info mb-0">
                <strong>Admin kontrol notu:</strong> @Model.Output.AdminNote
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-copy-target]').forEach((button) => {
            button.addEventListener('click', async () => {
                const targetId = button.getAttribute('data-copy-target');
                const target = targetId ? document.getElementById(targetId) : null;
                if (!target) return;

                target.select();
                target.setSelectionRange(0, target.value.length);

                try {
                    await navigator.clipboard.writeText(target.value);
                    const oldText = button.textContent;
                    button.textContent = 'Kopyalandı';
                    window.setTimeout(() => {
                        button.textContent = oldText;
                    }, 1500);
                } catch {
                    document.execCommand('copy');
                }
            });
        });
    </script>
}
